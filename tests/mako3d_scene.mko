using Mako3D;

# The scene/object system's data management (spawn/set/remove/count/bounds)
# is pure state — no window needed — so it's fully testable headlessly.
# draw_scene() itself needs an open window and isn't exercised here.

main() {
    Mako3D.clear_objects();
    assert(Mako3D.object_count() == 0, "starts empty");

    cube = Mako3D.spawn_cube(0, 1, 0,  2, 2, 2, Mako3D.RED);
    assert(Mako3D.object_count() == 1, "spawn_cube adds one object");

    sphere = Mako3D.spawn_sphere(5, 1, 0,  1.5, Mako3D.BLUE);
    cyl    = Mako3D.spawn_cylinder(-5, 0, 0,  0.8, 0.8, 2, Mako3D.GREEN);
    plane  = Mako3D.spawn_plane(0, 0, 0,  10, 10, Mako3D.GRAY);
    assert(Mako3D.object_count() == 4, "spawn_* each add one object");

    # Handles are distinct
    assert(cube != sphere and sphere != cyl and cyl != plane, "handles are unique");

    # Mutating a spawned object
    Mako3D.set_object_pos(cube, 3, 2, 1);
    Mako3D.set_object_color(cube, Mako3D.GOLD);
    Mako3D.set_object_scale(cube, 4, 4, 4);
    Mako3D.set_object_rotation(cube, 45);
    Mako3D.set_object_visible(sphere, false);
    Mako3D.set_object_wires(sphere, false);

    # object_bounds reflects the mutated position/scale
    bounds = Mako3D.object_bounds(cube);
    assert(len(bounds) == 6, "bounds returns [minx,miny,minz,maxx,maxy,maxz]");
    assert(abs(bounds[0] - 1) < 0.001, "bounds min_x reflects moved position + half scale");
    assert(abs(bounds[3] - 5) < 0.001, "bounds max_x reflects moved position + half scale");

    sphere_bounds = Mako3D.object_bounds(sphere);
    assert(abs(sphere_bounds[3] - sphere_bounds[0] - 3) < 0.001, "sphere bounds width = 2*radius");

    # Removal
    Mako3D.remove_object(sphere);
    assert(Mako3D.object_count() == 3, "remove_object shrinks the count");
    assert(Mako3D.object_bounds(sphere) == none, "a removed object's bounds are none");

    # Removing/mutating an invalid handle is a safe no-op, not a crash
    Mako3D.set_object_pos(999, 0, 0, 0);
    Mako3D.remove_object(999);
    assert(Mako3D.object_count() == 3, "operations on a bad handle don't corrupt state");

    # object_info() is the read side of set_object_* — for editor/inspector panels
    info = Mako3D.object_info(cube);
    assert(info["shape"] == "cube", "object_info reports shape");
    assert(abs(info["x"] - 3) < 0.001, "object_info reflects set_object_pos");
    assert(abs(info["sx"] - 4) < 0.001, "object_info reflects set_object_scale");
    assert(abs(info["rotation"] - 45) < 0.001, "object_info reflects set_object_rotation");
    assert(info["color"][0] == Mako3D.GOLD[0], "object_info reflects set_object_color");
    assert(info["visible"] == true, "object_info reports visibility");
    assert(Mako3D.object_info(999) == none, "object_info on a bad handle is none");

    # box3d_overlap / dist3d
    assert(dist3d(0, 0, 0,  3, 4, 0) == 5, "dist3d — 3-4-5 right triangle");
    assert(box3d_overlap(0,0,0, 2,2,2,  1,1,1, 3,3,3), "overlapping boxes");
    assert(not box3d_overlap(0,0,0, 1,1,1,  5,5,5, 6,6,6), "non-overlapping boxes");

    # Two objects' own bounds actually overlap in world space
    Mako3D.clear_objects();
    a = Mako3D.spawn_cube(0, 0, 0,  4, 4, 4, Mako3D.RED);      # spans -2..2
    b = Mako3D.spawn_cube(3, 0, 0,  4, 4, 4, Mako3D.BLUE);     # spans 1..5 — overlaps a
    c = Mako3D.spawn_cube(20, 0, 0, 4, 4, 4, Mako3D.GREEN);    # far away — no overlap
    ba = Mako3D.object_bounds(a);
    bb = Mako3D.object_bounds(b);
    bc = Mako3D.object_bounds(c);
    assert(box3d_overlap(ba[0],ba[1],ba[2], ba[3],ba[4],ba[5],
                          bb[0],bb[1],bb[2], bb[3],bb[4],bb[5]), "adjacent cubes overlap");
    assert(not box3d_overlap(ba[0],ba[1],ba[2], ba[3],ba[4],ba[5],
                              bc[0],bc[1],bc[2], bc[3],bc[4],bc[5]), "far cubes don't overlap");

    Mako3D.clear_objects();
    assert(Mako3D.object_count() == 0, "clear_objects empties the scene");

    # ── save_scene / load_scene round-trip ───────────────────────────────────
    Mako3D.clear_objects();
    cube2 = Mako3D.spawn_cube(1, 2, 3,  4, 5, 6, Mako3D.RED);
    Mako3D.set_object_rotation(cube2, 45);
    sphere2 = Mako3D.spawn_sphere(-2, 0, 0,  1.5, Mako3D.BLUE);
    Mako3D.set_object_visible(sphere2, false);

    Mako3D.save_scene("/tmp/mako_scene_test.json");
    Mako3D.clear_objects();
    assert(Mako3D.object_count() == 0, "cleared before reload");

    Mako3D.load_scene("/tmp/mako_scene_test.json");
    assert(Mako3D.object_count() == 2, "load_scene restores every object");

    info0 = Mako3D.object_info(0);
    assert(info0["shape"] == "cube", "load_scene restores shape");
    assert(abs(info0["x"] - 1) < 0.001, "load_scene restores position");
    assert(abs(info0["sy"] - 5) < 0.001, "load_scene restores scale");
    assert(abs(info0["rotation"] - 45) < 0.001, "load_scene restores rotation");
    assert(info0["color"][0] == Mako3D.RED[0], "load_scene restores color");

    info1 = Mako3D.object_info(1);
    assert(info1["shape"] == "sphere", "load_scene restores second object's shape");
    assert(info1["visible"] == false, "load_scene restores visibility");

    caught = false;
    try { Mako3D.load_scene("/tmp/does_not_exist_xyz.json"); }
    catch err { caught = true; }
    assert(caught, "load_scene on a missing file is a catchable error");

    delete("/tmp/mako_scene_test.json");
    Mako3D.clear_objects();

    print "Mako3D scene tests pass!";
}
