# Sanity check that mko fmt doesn't crash on constructs across the language:
# dicts, lambdas, try/catch (including an empty catch body), template strings.
main() {
    d = {"a": 1, "b": 2};
    f = fn(x) => x * 2;
    g = fn(x) {
        return x + 1;
    };

    try {
        assert(false, "x");
    } catch {
    }

    try {
        assert(true, "y");
    } catch err {
        print err;
    }

    name = "world";
    assert("hello {name}" == "hello world", "template string works after formatting");
    assert("{f(2)} and {g(3)} and {d["a"]}" == "4 and 4 and 1", "nested calls + dict index in template");

    assert(f(5) == 10, "lambda still works after being formatted-over");
    assert(d["b"] == 2, "dict still works");

    # Precedence-changing parens must round-trip through mko fmt unchanged —
    # the formatter used to drop them, silently turning (2+3)*20 into 2+3*20.
    assert((2 + 3) * 20 == 100, "parens raise + above * before multiply");
    assert(10 - (3 - 1) == 8, "parens override left-associativity of -");
    assert(not (true and false), "parens override and inside not");
    assert(-(4 + 5) == -9, "parens bind unary minus over the whole sum");
}
