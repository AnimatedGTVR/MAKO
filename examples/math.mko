// Arithmetic and numeric comparisons.

script "Math";

main() {
    a = 20;
    b = 6;

    print "a     = " + a;
    print "b     = " + b;
    print "a + b = " + (a + b);
    print "a - b = " + (a - b);
    print "a * b = " + (a * b);
    print "a / b = " + (a / b);

    if a > b {
        print "a is greater than b";
    }
    else if a == b {
        print "a equals b";
    }
    else {
        print "b is greater than a";
    }
}
